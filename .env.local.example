# CharmLink environment variables — copy to .env.local for local development
# Add all of these to Vercel (Settings → Environment Variables) for production.

# REQUIRED: 64-char hex secret for HMAC link tokens.
# Generate with: openssl rand -hex 32
# Must be set in Vercel (production + preview + dev) before merge.
CHARMLINK_LINK_TOKEN_SECRET=<replace_with_64_char_hex_from_openssl_rand_hex_32>
