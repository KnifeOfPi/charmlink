# CharmLink environment variables — copy to .env.local for local development
# Add all of these to Vercel (Settings → Environment Variables) for production.

# REQUIRED: 64-char hex secret for HMAC link tokens.
# Generate with: openssl rand -hex 32
# Must be set in Vercel (production + preview + dev) before merge.
CHARMLINK_LINK_TOKEN_SECRET=<replace_with_64_char_hex_from_openssl_rand_hex_32>

# OPTIONAL: Vercel KV — enables per-IP sliding-window rate limiting and
# honeypot ban list. If unset, rate limiting is silently disabled (no errors).
# Provision via: Vercel Dashboard → Storage → KV → Create → copy env vars.
KV_REST_API_URL=<vercel_kv_rest_api_url>
KV_REST_API_TOKEN=<vercel_kv_rest_api_token>

# OPTIONAL (Phase 3): Cloudflare API token — enables automatic CF zone provisioning
# (orange-cloud CNAME, WAF rules, transform rules) when adding domains via admin API.
# If unset, CF provisioning is silently skipped (Vercel domain still added).
# Token must have Zone:DNS:Edit + Zone:Settings:Edit + Zone:Firewall Services:Edit
# on all CharmLink zones. Scoped token — NOT the global API key.
CLOUDFLARE_API_TOKEN=<cfat_...>

# OPTIONAL (Phase 3): Cloudflare Turnstile — escalates suspicious requests to
# human verification. Both keys must be set to enable Turnstile.
# Provision: CF Dashboard → Turnstile → Add site → Managed mode → copy keys.
# If unset, Turnstile gate is skipped (all non-bot requests pass through).
TURNSTILE_SECRET_KEY=<cloudflare_turnstile_secret_key>
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<cloudflare_turnstile_site_key>
